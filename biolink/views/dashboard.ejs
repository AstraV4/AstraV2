<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Mon profil</title>
<link rel="stylesheet" href="/static/css/app.css" />
<style>
#musicResults{display:flex;flex-direction:column;gap:6px;margin-top:8px}
.music-row{display:flex;align-items:center;gap:10px;padding:7px 9px;border-radius:11px;
  background:rgba(255,255,255,.04);border:1px solid var(--border)}
.music-row img{width:40px;height:40px;border-radius:8px;object-fit:cover;flex-shrink:0;background:#222}
.music-row span{flex:1;font-size:.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.music-row .mini{width:34px;height:34px;border-radius:9px;border:1px solid var(--border);
  background:rgba(255,255,255,.06);color:var(--text);cursor:pointer;flex-shrink:0}
.music-row .mini:hover{background:var(--accent)}
.skills-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px}
.skill-check{display:flex;align-items:center;gap:8px;padding:9px 11px;border-radius:11px;
  background:rgba(255,255,255,.04);border:1px solid var(--border);cursor:pointer;font-size:.86rem}
.skill-check input{width:auto;margin:0}
.skill-check:hover{border-color:var(--accent)}
</style>
</head>
<body>
<div class="hero-glow"></div>
<div class="container dash">

  <div class="dash-head">
    <div>
      <h2>Modifier mon profil</h2>
      <div class="current">Ta page : <a href="/<%= u.username %>" target="_blank" style="color:var(--accent)"><%= siteName %>/<%= u.username %></a> · <%= u.views %> vues</div>
    </div>
    <nav style="display:flex;gap:10px">
      <% if (isAdmin) { %><a class="btn" href="/admin">🛠️ Admin</a><% } %>
      <a class="btn" href="/<%= u.username %>" target="_blank">👁 Voir ma page</a>
      <form method="POST" action="/logout"><button class="btn btn-danger" type="submit">Déconnexion</button></form>
    </nav>
  </div>

  <% if (saved) { %><div class="ok">✅ Profil enregistré !</div><% } %>
  <% if (pwok) { %><div class="ok">✅ Mot de passe changé !</div><% } %>
  <% if (pwerr === '1') { %><div class="error">❌ Mot de passe actuel incorrect.</div><% } %>
  <% if (pwerr === '2') { %><div class="error">❌ Le nouveau mot de passe doit faire au moins 6 caractères.</div><% } %>

  <form class="panel" method="POST" action="/dashboard" enctype="multipart/form-data">
    <div class="tabs" id="tabs">
      <button type="button" class="tab active" data-go="profil">👤 Profil</button>
      <button type="button" class="tab" data-go="apparence">🎨 Apparence</button>
      <button type="button" class="tab" data-go="media">🎵 Média</button>
      <button type="button" class="tab" data-go="liens">🔗 Liens</button>
      <button type="button" class="tab" data-go="infos">🏷️ Infos &amp; badges</button>
    </div>

    <div class="section" data-tab="profil">
      <h3>Identité</h3>
      <p class="hint">Pseudo : <b>@<%= u.username %></b> (non modifiable)</p>
      <div class="row2">
        <div>
          <label>Photo de profil (image)</label>
          <input type="file" name="avatar" accept="image/*" />
          <% if (u.avatar) { %><div class="current">Actuelle : <a href="<%= u.avatar %>" target="_blank">voir</a></div><% } %>
        </div>
        <div>
          <label>Statut</label>
          <select name="status">
            <% ['online','idle','dnd','offline',''].forEach(function(s){ %>
              <option value="<%= s %>" <%= u.status===s?'selected':'' %>><%= s||'(aucun)' %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <label>Sous-titre / localisation</label>
      <input type="text" name="title" value="<%= u.title %>" maxlength="80" placeholder="ex: développeur · Paris" />
      <label>Bio (une ligne = un message qui défile, max 6)</label>
      <textarea name="bio" placeholder="Bienvenue sur mon profil&#10;merci de ta visite !"><%= bio %></textarea>
    </div>

    <div class="section" data-tab="apparence">
      <h3>Apparence</h3>
      <div class="row2">
        <div><label>Couleur principale</label><input type="color" name="accent" id="acc1" value="<%= u.accent %>" /></div>
        <div><label>Couleur secondaire</label><input type="color" name="accent2" id="acc2" value="<%= u.accent2 %>" /></div>
      </div>
      <label>🌈 Thèmes rapides (1 clic)</label>
      <div id="themes" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:6px">
        <% [['Violet/Cyan','#8b5cf6','#22d3ee'],['Rose/Orange','#ec4899','#f59e0b'],['Vert/Bleu','#22c55e','#3b82f6'],['Rouge/Noir','#ef4444','#1f2937'],['Or/Ambre','#fbbf24','#f59e0b'],['Cyan/Violet','#06b6d4','#a855f7'],['Rose/Violet','#f472b6','#8b5cf6'],['Lime/Teal','#84cc16','#14b8a6'],['Bleu glace','#60a5fa','#bae6fd']].forEach(function(t){ %>
          <button type="button" class="theme-swatch" data-c1="<%= t[1] %>" data-c2="<%= t[2] %>" title="<%= t[0] %>" style="background:linear-gradient(135deg,<%= t[1] %>,<%= t[2] %>)"></button>
        <% }) %>
      </div>
      <div class="row2">
        <div>
          <label>Effet de fond</label>
          <select name="effect">
            <% [['snow','Neige'],['rain','Pluie'],['stars','Étoiles'],['none','Aucun']].forEach(function(e){ %>
              <option value="<%= e[0] %>" <%= u.effect===e[0]?'selected':'' %>><%= e[1] %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>Curseur</label>
          <select name="cursor_style">
            <% [['none','Normal'],['magnet','Magnet ✨ (premium)'],['glow','Halo'],['ring','Anneau'],['dot','Point'],['cross','Croix'],['orbit','Orbite'],['trail','Traînée'],['comet','Comète ☄️'],['sparkle','Étincelles ✨'],['droplets','Gouttes d\u2019eau 💧'],['fire','Feu 🔥'],['hearts','Cœurs 💖'],['stars','Étoiles ⭐'],['bubbles','Bulles 🫧'],['snowtrail','Neige ❄️'],['petals','Pétales 🌸'],['neon','Néon'],['rainbow','Arc-en-ciel 🌈'],['image','Image perso 🖼️'],['image-trail','Image + traînée'],['image-drops','Image + gouttes 💧']].forEach(function(c){ %>
              <option value="<%= c[0] %>" <%= (u.cursor_style||'none')===c[0]?'selected':'' %>><%= c[1] %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="row2">
        <div>
          <label>Carte du profil</label>
          <select name="card_style">
            <% [['glass','Verre dépoli'],['solid','Fond plein'],['none','Aucune (transparent)']].forEach(function(c){ %>
              <option value="<%= c[0] %>" <%= (u.card_style||'glass')===c[0]?'selected':'' %>><%= c[1] %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>Forme de la carte</label>
          <select name="card_shape">
            <% [['rounded','Arrondie'],['square','Carrée'],['round','Très arrondie']].forEach(function(c){ %>
              <option value="<%= c[0] %>" <%= (u.card_shape||'rounded')===c[0]?'selected':'' %>><%= c[1] %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <label>🌫️ Intensité du flou de la carte (verre dépoli)</label>
      <select name="card_blur">
        <% [['none','Aucun (net)'],['light','Léger'],['medium','Moyen'],['strong','Fort']].forEach(function(c){ %>
          <option value="<%= c[0] %>" <%= (u.card_blur||'strong')===c[0]?'selected':'' %>><%= c[1] %></option>
        <% }) %>
      </select>
      <div class="row2">
        <div>
          <label>Forme de l'avatar</label>
          <select name="avatar_shape">
            <% [['circle','Rond'],['rounded','Arrondi'],['square','Carré'],['none','Aucun (pas de photo)']].forEach(function(c){ %>
              <option value="<%= c[0] %>" <%= (u.avatar_shape||'circle')===c[0]?'selected':'' %>><%= c[1] %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>Taille de l'avatar</label>
          <select name="avatar_size">
            <% [['sm','Petit'],['md','Moyen'],['lg','Grand'],['xl','Très grand']].forEach(function(c){ %>
              <option value="<%= c[0] %>" <%= (u.avatar_size||'md')===c[0]?'selected':'' %>><%= c[1] %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:12px">
        <input type="checkbox" name="show_uid" id="show_uid" style="width:auto" <%= u.show_uid?'checked':'' %> />
        <label for="show_uid" style="margin:0">Afficher mon UID (numéro de membre) sur le profil</label>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:10px">
        <input type="checkbox" name="avatar_glow" id="avatar_glow" style="width:auto" <%= u.avatar_glow?'checked':'' %> />
        <label for="avatar_glow" style="margin:0">✨ Halo animé autour de l'avatar</label>
      </div>

      <div class="row2" style="margin-top:14px">
        <div>
          <label>🎨 Couleur des badges</label>
          <select name="badge_style">
            <% [['multi','Multicolore (défaut)'],['accent','Mes couleurs d\u2019accent'],['custom','Couleur personnalisée']].forEach(function(o){ %>
              <option value="<%= o[0] %>" <%= (u.badge_style||'multi')===o[0]?'selected':'' %>><%= o[1] %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>Couleur perso des badges</label>
          <input type="color" name="badge_color" value="<%= u.badge_color || '#8b5cf6' %>" style="height:46px;padding:4px" />
        </div>
      </div>
      <label style="margin-top:8px">🌫️ Flou du fond</label>
      <select name="bg_blur">
        <% [['none','Aucun'],['light','Léger'],['strong','Fort']].forEach(function(o){ %>
          <option value="<%= o[0] %>" <%= (u.bg_blur||'none')===o[0]?'selected':'' %>><%= o[1] %></option>
        <% }) %>
      </select>

      <label style="margin-top:14px">🖼️ Image de curseur personnalisé (PNG/GIF/WebP)</label>
      <input type="file" name="cursor_image" accept="image/*" />
      <label>… ou colle le lien d'un curseur trouvé sur un site</label>
      <input type="text" name="cursor_image_url" value="<%= /^https?:/.test(u.cursor_image||'') ? u.cursor_image : '' %>" placeholder="https://.../curseur.png" />
      <div class="hint">Choisis ensuite le curseur « Image perso » ou « Image + traînée » plus haut. Petite image carrée (~40px) à fond transparent recommandée.<% if (u.cursor_image) { %> · <a href="<%= u.cursor_image %>" target="_blank" style="color:var(--accent)">curseur actuel</a><% } %></div>

      <div class="row2" style="margin-top:14px">
        <div>
          <label>✨ Effet du pseudo</label>
          <select name="username_effect">
            <% [['none','Aucun'],['gradient','Dégradé animé'],['glow','Lueur'],['shine','Reflet brillant']].forEach(function(e){ %>
              <option value="<%= e[0] %>" <%= (u.username_effect||'none')===e[0]?'selected':'' %>><%= e[1] %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>Texte de l'écran d'entrée</label>
          <input type="text" name="enter_text" value="<%= u.enter_text %>" maxlength="40" placeholder="click to enter" />
        </div>
      </div>
      <label style="margin-top:8px">🎬 Animation d'entrée</label>
      <select name="enter_anim">
        <% [['fade','Fondu'],['zoom','Zoom'],['slide','Glissé'],['blur','Flou'],['flip','Flip 3D']].forEach(function(o){ %>
          <option value="<%= o[0] %>" <%= (u.enter_anim||'fade')===o[0]?'selected':'' %>><%= o[1] %></option>
        <% }) %>
      </select>
    </div>

    <div class="section" data-tab="media">
      <h3>Fond</h3>
      <p class="hint">Image ou vidéo (mp4/webm). 50 Mo max.</p>
      <label>Fond (image ou vidéo)</label>
      <input type="file" name="background" accept="image/*,video/mp4,video/webm" />
      <% if (u.background) { %><div class="current">Actuel : <a href="<%= u.background %>" target="_blank">voir</a></div><% } %>

      <label style="margin-top:14px">🖼️ Bannière (couverture en haut du profil)</label>
      <input type="file" name="banner" accept="image/*" />
      <div class="hint">Image large recommandée (ex: 1200×400). Elle s'affiche en haut de ta carte, avec l'avatar par-dessus.</div>
      <% if (u.banner) { %>
        <div class="current">Actuelle : <a href="<%= u.banner %>" target="_blank">voir</a>
          <label style="display:inline-flex;align-items:center;gap:6px;margin-left:10px;font-weight:400"><input type="checkbox" name="banner_clear" value="1" style="width:auto" /> retirer la bannière</label>
        </div>
      <% } %>
    </div>

    <div class="section" data-tab="media">
      <h3>Musique de fond</h3>
      <p class="hint">Cherche une musique (aperçu ~30 s) OU envoie ton propre fichier audio complet.</p>

      <label>🔎 Rechercher une musique</label>
      <input type="text" id="musicSearch" placeholder="Titre ou artiste (ex: Drake)" autocomplete="off" />
      <div id="musicResults"></div>

      <div id="selectedSong" class="current" style="margin-top:8px">
        <% if (u.song) { %>🎵 Sélection actuelle : <b><%= u.song_name || u.song %></b><% } %>
      </div>
      <input type="hidden" name="song_url" id="song_url" value="<%= /^https?:/.test(u.song) ? u.song : '' %>" />
      <input type="hidden" name="song_art" id="song_art" value="<%= u.song_art || '' %>" />

      <label style="margin-top:14px">Ou envoyer un fichier audio (musique complète)</label>
      <input type="file" name="song" accept="audio/*" />

      <label>Nom affiché dans le lecteur</label>
      <input type="text" name="song_name" id="song_name" value="<%= u.song_name %>" maxlength="80" placeholder="Artiste - Titre" />
    </div>

    <div class="section" data-tab="liens">
      <h3>Liens sociaux (icônes)</h3>
      <p class="hint">Types dispo : discord, github, instagram, x, youtube, spotify, tiktok, telegram, email, globe</p>
      <div id="socials">
        <% (socials.length?socials:[{type:'',url:''}]).forEach(function(s){ %>
          <div class="repeat-row">
            <select name="social_type">
              <% ['discord','github','instagram','x','youtube','spotify','tiktok','telegram','email','globe'].forEach(function(t){ %>
                <option value="<%= t %>" <%= s.type===t?'selected':'' %>><%= t %></option>
              <% }) %>
            </select>
            <input type="text" name="social_url" value="<%= s.url %>" placeholder="https://..." />
            <button type="button" class="btn btn-danger" onclick="this.parentElement.remove()">✕</button>
          </div>
        <% }) %>
      </div>
      <button type="button" class="btn btn-add" onclick="addSocial()">+ Ajouter un lien</button>
    </div>

    <div class="section" data-tab="liens">
      <h3>Boutons texte (optionnel)</h3>
      <div id="buttons">
        <% buttons.forEach(function(bn){ %>
          <div class="repeat-row">
            <input type="text" name="btn_label" value="<%= bn.label %>" placeholder="Libellé" />
            <input type="text" name="btn_url" value="<%= bn.url %>" placeholder="https://..." />
            <button type="button" class="btn btn-danger" onclick="this.parentElement.remove()">✕</button>
          </div>
        <% }) %>
      </div>
      <button type="button" class="btn btn-add" onclick="addButton()">+ Ajouter un bouton</button>
    </div>

    <div class="section" data-tab="infos">
      <h3>Widgets & infos</h3>
      <div class="row2">
        <div>
          <label>⏰ Fuseau horaire (horloge en direct)</label>
          <select name="timezone">
            <% allowedTz.forEach(function(tz){ %>
              <option value="<%= tz %>" <%= u.timezone===tz?'selected':'' %>><%= tz || '(aucun)' %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label>📍 Localisation (texte affiché)</label>
          <input type="text" name="location" value="<%= u.location %>" maxlength="40" placeholder="ex: Paris, France" />
        </div>
      </div>

      <label>💬 ID du serveur Discord (widget serveur)</label>
      <input type="text" name="discord_guild" value="<%= u.discord_guild %>" placeholder="ex: 1043523929361723402" />
      <div class="hint">Active d'abord le widget sur ton serveur : Paramètres du serveur → Widget → « Activer le widget ». Puis colle l'ID du serveur (clic droit sur le serveur → Copier l'identifiant, en mode développeur).</div>

      <label>🟢 Ton ID utilisateur Discord (présence en direct)</label>
      <input type="text" name="discord_user" value="<%= u.discord_user %>" placeholder="ex: 338529452322422784" />
      <div class="hint">Affiche ton statut/activité en direct. Rejoins d'abord le serveur Lanyard (<b>discord.gg/lanyard</b>), puis colle ton ID utilisateur Discord ici.</div>
    </div>

    <div class="section" data-tab="infos">
      <h3>🏷️ Compétences / badges</h3>
      <p class="hint">Coche celles à afficher sur ta page (max 12).</p>
      <div class="skills-grid">
        <% allowedSkills.forEach(function(sk){ %>
          <label class="skill-check">
            <input type="checkbox" name="skills" value="<%= sk %>" <%= skills.indexOf(sk)>=0?'checked':'' %> />
            <span><%= sk %></span>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="bar">
      <button class="btn btn-primary" type="submit">💾 Enregistrer</button>
      <a class="btn" href="/<%= u.username %>" target="_blank">Prévisualiser</a>
    </div>
  </form>

  <div class="panel" style="margin-top:20px">
    <h3 style="margin-bottom:6px">🔑 Changer mon mot de passe</h3>
    <p class="hint">Saisis ton mot de passe actuel (ou le mot de passe temporaire donné par un admin), puis ton nouveau mot de passe.</p>
    <form method="POST" action="/account/password">
      <div class="row2">
        <div>
          <label>Mot de passe actuel</label>
          <input type="password" name="current" required />
        </div>
        <div>
          <label>Nouveau mot de passe</label>
          <input type="password" name="new" placeholder="6 caractères minimum" required />
        </div>
      </div>
      <button class="btn btn-primary" type="submit" style="margin-top:12px">Changer le mot de passe</button>
    </form>
  </div>

  <div class="panel" style="margin-top:20px;border-color:rgba(239,68,68,.3)">
    <h3 style="color:#fca5a5;margin-bottom:6px">Zone de danger</h3>
    <p class="hint">La suppression de ton compte est définitive : profil, fichiers et données seront perdus.</p>
    <form method="POST" action="/account/delete" onsubmit="return confirm('Supprimer ton compte définitivement ? Cette action est irréversible.')">
      <button class="btn btn-danger" type="submit">Supprimer mon compte</button>
    </form>
  </div>
</div>

<script>
// Navigation par onglets
(function(){
  const tabs = document.getElementById('tabs');
  if (!tabs) return;
  const btns = tabs.querySelectorAll('.tab');
  const sections = document.querySelectorAll('.section[data-tab]');
  function show(go){
    sections.forEach(s => { s.style.display = (s.dataset.tab === go ? '' : 'none'); });
    btns.forEach(b => b.classList.toggle('active', b.dataset.go === go));
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  btns.forEach(b => b.addEventListener('click', () => show(b.dataset.go)));
  show('profil');
})();
// Thèmes de couleurs rapides
(function(){
  const themes = document.getElementById('themes');
  if (!themes) return;
  themes.querySelectorAll('.theme-swatch').forEach(b => {
    b.addEventListener('click', () => {
      const a1 = document.getElementById('acc1'), a2 = document.getElementById('acc2');
      if (a1) a1.value = b.dataset.c1;
      if (a2) a2.value = b.dataset.c2;
    });
  });
})();
const SOCIAL_TYPES = ['discord','github','instagram','x','youtube','spotify','tiktok','telegram','email','globe'];
function addSocial(){
  const row = document.createElement('div');
  row.className = 'repeat-row';
  const sel = '<select name="social_type">' + SOCIAL_TYPES.map(t=>`<option value="${t}">${t}</option>`).join('') + '</select>';
  row.innerHTML = sel + '<input type="text" name="social_url" placeholder="https://..." />' +
    '<button type="button" class="btn btn-danger" onclick="this.parentElement.remove()">✕</button>';
  document.getElementById('socials').appendChild(row);
}
function addButton(){
  const row = document.createElement('div');
  row.className = 'repeat-row';
  row.innerHTML = '<input type="text" name="btn_label" placeholder="Libellé" />' +
    '<input type="text" name="btn_url" placeholder="https://..." />' +
    '<button type="button" class="btn btn-danger" onclick="this.parentElement.remove()">✕</button>';
  document.getElementById('buttons').appendChild(row);
}

// ---- Recherche de musique (API iTunes via notre serveur) ----
const musicSearch = document.getElementById('musicSearch');
const musicResults = document.getElementById('musicResults');
let mt, preview = null;
if (musicSearch) musicSearch.addEventListener('input', () => {
  clearTimeout(mt);
  const q = musicSearch.value.trim();
  if (q.length < 2) { musicResults.innerHTML = ''; return; }
  mt = setTimeout(async () => {
    musicResults.innerHTML = '<div class="current">Recherche…</div>';
    try {
      const r = await fetch('/api/music/search?q=' + encodeURIComponent(q));
      const list = await r.json();
      musicResults.innerHTML = '';
      if (!list.length) { musicResults.innerHTML = '<div class="current">Aucun résultat.</div>'; return; }
      list.forEach(t => {
        const row = document.createElement('div');
        row.className = 'music-row';

        const img = document.createElement('img'); img.src = t.art; img.alt = '';
        const span = document.createElement('span'); span.textContent = t.name; // textContent => sans danger

        const playBtn = document.createElement('button');
        playBtn.type = 'button'; playBtn.className = 'mini'; playBtn.textContent = '▶';
        playBtn.title = 'Écouter un extrait';
        playBtn.addEventListener('click', () => {
          if (preview) { preview.pause(); }
          preview = new Audio(t.url); preview.volume = 0.6; preview.play().catch(()=>{});
        });

        const pick = document.createElement('button');
        pick.type = 'button'; pick.className = 'btn'; pick.style.padding = '7px 12px'; pick.textContent = 'Choisir';
        pick.addEventListener('click', () => {
          document.getElementById('song_url').value = t.url;
          document.getElementById('song_art').value = t.art;
          document.getElementById('song_name').value = t.name;
          const sel = document.getElementById('selectedSong');
          sel.textContent = '🎵 Sélection : '; const b = document.createElement('b'); b.textContent = t.name; sel.appendChild(b);
          if (preview) preview.pause();
          musicResults.innerHTML = '';
          musicSearch.value = '';
        });

        row.appendChild(img); row.appendChild(span); row.appendChild(playBtn); row.appendChild(pick);
        musicResults.appendChild(row);
      });
    } catch (e) {
      musicResults.innerHTML = '<div class="current">Erreur de recherche, réessaie.</div>';
    }
  }, 350);
});
</script>
