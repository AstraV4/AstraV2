<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Admin · <%= siteName %></title>
<link rel="stylesheet" href="/static/css/app.css" />
<style>
.uadmin{padding:18px;border-radius:16px;background:var(--panel);border:1px solid var(--border);margin-bottom:14px}
.uadmin-head{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:12px}
.bgrid{display:flex;flex-wrap:wrap;gap:7px}
.btoggle{padding:6px 11px;font-size:.78rem;border-radius:9px;border:1px solid var(--border);background:rgba(255,255,255,.04);color:var(--dim);cursor:pointer;transition:.18s;font-family:inherit}
.btoggle:hover{border-color:var(--accent)}
.btoggle.on{background:linear-gradient(135deg,var(--accent),var(--accent-2));color:#fff;border:none}
</style>
</head>
<body>
<div class="hero-glow"></div>
<div class="container dash">
  <div class="dash-head">
    <div><h2>🛠️ Panneau admin</h2><div class="current"><%= users.length %> compte<%= users.length>1?'s':'' %></div></div>
    <nav style="display:flex;gap:10px"><a class="btn" href="/dashboard">Mon profil</a></nav>
  </div>

  <% if (resetInfo) { %>
    <div class="panel" style="border-color:var(--accent);margin-bottom:14px">
      <h3 style="margin-bottom:6px">🔑 Mot de passe réinitialisé pour @<%= resetInfo.username %></h3>
      <p class="hint" style="margin-bottom:10px">Donne-lui ce mot de passe temporaire (il pourra le changer ensuite dans son profil) :</p>
      <div style="font-family:monospace;font-size:1.3rem;letter-spacing:2px;background:rgba(139,92,246,.12);border:1px solid var(--accent);border-radius:10px;padding:12px;text-align:center"><%= resetInfo.password %></div>
    </div>
  <% } %>

  <% users.forEach(function(u){ %>
    <div class="uadmin">
      <div class="uadmin-head">
        <div>
          <a href="/<%= u.username %>" target="_blank" style="color:var(--accent);font-weight:700;font-size:1.05rem">@<%= u.username %></a>
          <span class="current"> · <%= u.views %> vues · <%= u.badges.length %> badge<%= u.badges.length>1?'s':'' %></span>
          <div class="current" style="margin-top:6px;line-height:1.6">
            🕓 Inscrit le <%= new Date(u.createdAt).toLocaleString('fr-FR') %><br/>
            🔌 Dernière connexion : <%= u.lastLogin ? new Date(u.lastLogin).toLocaleString('fr-FR') : '—' %><br/>
            🌐 IP inscription : <%= u.signupIp || '—' %><% if (u.signupIp) { %> <a href="https://ipinfo.io/<%= u.signupIp %>" target="_blank" style="color:var(--accent)">(localiser)</a><% } %><br/>
            🌐 IP dernière connexion : <%= u.lastIp || '—' %><% if (u.lastIp && u.lastIp !== u.signupIp) { %> <a href="https://ipinfo.io/<%= u.lastIp %>" target="_blank" style="color:var(--accent)">(localiser)</a><% } %>
          </div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <form method="POST" action="/admin/resetpw" onsubmit="return confirm('Générer un nouveau mot de passe temporaire pour @<%= u.username %> ?')">
            <input type="hidden" name="id" value="<%= u.id %>"/>
            <button class="btn" type="submit" style="padding:7px 12px;font-size:.8rem">🔑 Réinit. MDP</button>
          </form>
          <form method="POST" action="/admin/delete" onsubmit="return confirm('Supprimer @<%= u.username %> définitivement ?')">
            <input type="hidden" name="id" value="<%= u.id %>"/>
            <button class="btn btn-danger" type="submit" style="padding:7px 12px;font-size:.8rem">Supprimer</button>
          </form>
        </div>
      </div>
      <div class="bgrid">
        <% catalog.forEach(function(c){ %>
          <form method="POST" action="/admin/badge" style="display:inline">
            <input type="hidden" name="id" value="<%= u.id %>"/>
            <input type="hidden" name="key" value="<%= c.key %>"/>
            <button class="btoggle <%= u.badges.indexOf(c.key)>=0?'on':'' %>" type="submit"><%= c.label %></button>
          </form>
        <% }) %>
      </div>
      <form method="POST" action="/admin/addviews" style="display:flex;gap:8px;align-items:center;margin-top:12px;flex-wrap:wrap">
        <input type="hidden" name="id" value="<%= u.id %>"/>
        <span class="current">👁️ Ajouter des vues :</span>
        <input type="number" name="amount" value="100" style="width:110px;padding:7px 10px" />
        <button class="btn" type="submit" style="padding:7px 12px;font-size:.8rem">Ajouter</button>
      </form>
      <form method="POST" action="/admin/addlikes" style="display:flex;gap:8px;align-items:center;margin-top:8px;flex-wrap:wrap">
        <input type="hidden" name="id" value="<%= u.id %>"/>
        <span class="current">❤️ Ajouter des likes <small>(actuel : <%= u.likes %>)</small> :</span>
        <input type="number" name="amount" value="10" style="width:110px;padding:7px 10px" />
        <button class="btn" type="submit" style="padding:7px 12px;font-size:.8rem">Ajouter</button>
      </form>
    </div>
  <% }) %>
</div>
</body>
</html>
