<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>S'inscrire</title>
<link rel="stylesheet" href="/static/css/app.css" />
</head>
<body>
<div class="container"><header><a href="/" class="logo"><%= siteName %></a></header></div>
<div class="auth-wrap">
  <form class="auth panel" method="POST" action="/register">
    <h2>Créer un compte</h2>
    <p class="sub">Choisis ton pseudo, c'est l'adresse de ta page.</p>
    <% if (error) { %><div class="error"><%= error %></div><% } %>

    <label>Pseudo</label>
    <input type="text" name="username" value="<%= username %>" placeholder="tonpseudo" autocomplete="username"
           pattern="[a-zA-Z0-9_]{1,20}" required autofocus />

    <label>Mot de passe</label>
    <input type="password" name="password" placeholder="6 caractères minimum" autocomplete="new-password" required />

    <button class="btn btn-primary full" type="submit">Créer mon profil</button>
    <p class="muted">Déjà un compte ? <a href="/login" style="color:var(--accent)">Se connecter</a></p>
  </form>
</div>
</body>
</html>
